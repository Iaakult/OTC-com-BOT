MainWindow
  id: imbuingWindow
  !text: tr('Imbuement Shrine')
  size: 740 640
  @onEscape: modules.game_imbuing.Imbuement.close()
  Panel
    id: contentPanel
    anchors.fill: parent
    margin: 12 12 12 12

    SelectItemOrScroll
      id: selectItemOrScroll
      visible: true

    ScrollImbue
      id: scrollImbue
      visible: false

    SelectImbue
      id: selectImbue
      visible: false
    
    ClearImbue
      id: clearImbue
      visible: false

    HorizontalSeparator
      id: bottomSep
      anchors.left: parent.left
      anchors.right: parent.right
      anchors.bottom: close.top
      margin-bottom: 11
    Button
      id: close
      !text: tr('Close')
      size: 43 20
      anchors.right: parent.right
      anchors.bottom: parent.bottom
      @onClick: modules.game_imbuing.Imbuement.close()
