      color: #909090
      text-auto-resize: true
    Panel
      id: itemOrScrollContent
      anchors.fill: parent
      margin: 27 12 10 12
      PickItemButton
      ScrollItemButton

      Panel
        id: slots
        size: 208 66
        anchors.top: prev.top
        anchors.right: parent.right
        margin-top: -1
        margin-right: 18
        SlotImbuing
          id: slot0
